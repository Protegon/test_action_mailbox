IMAP_HOST=greenmail
IMAP_PORT=3143
IMAP_SSL=false
IMAP_USERNAME=support
IMAP_PASSWORD=change-me
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_MINUTES=5

# GreenMail is available in Docker Compose for SMTP + IMAP testing.
# Send test messages to support@mail.example.com through SMTP below.
SMTP_HOST=greenmail
SMTP_PORT=3025
SMTP_TO=support@mail.example.com
