<!DOCTYPE html>
<html>
  <head>
    <title>Chamados</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      :root {
        color-scheme: light;
        --bg: #f4f6f8;
        --panel: #ffffff;
        --border: #d8dee6;
        --text: #1f2933;
        --muted: #64748b;
        --accent: #1f6feb;
        --accent-soft: #e8f1ff;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Arial, Helvetica, sans-serif;
        line-height: 1.45;
      }

      .app-shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 240px 1fr;
      }

      .sidebar {
        background: #1f2933;
        color: #ffffff;
        padding: 24px 18px;
      }

      .brand {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 28px;
      }

      .nav-item {
        display: block;
        padding: 10px 12px;
        border-radius: 6px;
        color: #ffffff;
        text-decoration: none;
        background: rgba(255, 255, 255, 0.12);
      }

      .content {
        padding: 28px;
      }

      .page-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-end;
        margin-bottom: 18px;
      }

      h1 {
        margin: 0;
        font-size: 28px;
      }

      .muted {
        color: var(--muted);
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
        text-align: left;
        vertical-align: top;
      }

      th {
        background: #f8fafc;
        color: #475569;
        font-size: 12px;
        text-transform: uppercase;
      }

      tr:last-child td {
        border-bottom: 0;
      }

      a {
        color: var(--accent);
      }

      .status {
        display: inline-flex;
        align-items: center;
        min-height: 26px;
        padding: 0 10px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 12px;
        font-weight: 700;
      }

      .ticket-body {
        white-space: pre-wrap;
        padding: 18px;
      }

      @media (max-width: 760px) {
        .app-shell {
          grid-template-columns: 1fr;
        }

        .sidebar {
          padding: 18px;
        }

        .content {
          padding: 18px;
        }

        .page-header {
          display: block;
        }

        table,
        thead,
        tbody,
        th,
        td,
        tr {
          display: block;
        }

        thead {
          display: none;
        }

        td {
          border-bottom: 0;
          padding: 8px 14px;
        }

        tr {
          border-bottom: 1px solid var(--border);
          padding: 8px 0;
        }
      }
    </style>
  </head>

  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <div class="brand">Sistema de Chamados</div>
        <%= link_to "Chamados", tickets_path, class: "nav-item" %>
      </aside>
      <main class="content">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
